/dts-v1/;

/* Board-level configuration — demo seed overlay for aurora/nebula/atlas. */
/ {
	board_id = <12347>;
};

&amba {
	i2c@FDF5E000 {
		#address-cells = <1>;
		#size-cells = <0>;
		status = "ok";
		hold-time = <0x210021>;
		sc8562@6E {
			compatible = "sc8562";
			slave_mode = <1>;
			ic_role = <0>;
			reg = <0x6e>;
			fcp_support = <1>;
			scp_support = <1>;
			gpio_int = <&gpio13 29 0>;
			sense_r_config = <27>;
			sense_r_actual = <27>;
			watchdog_time = <8000>;
			vout_ovp_mv = <4800>;
			status = "ok";
		};
	};
};

&spmi1 {
	scharger_v800 {
		gpios = <&gpio5 31 0>;
		status = "ok";
		scharger_v800_buck {
			r_charger_uohm = <1100>;
			usbovp_sw_flag = "buck", "1", "1", "1";
			pswovp_sw_flag = "rxsw", "0", "0", "1";
			cur_balance_mos = <19>;
		};

		scharger_v800_coul {
			status = "ok";
			batt_l_v800 {
				batt_index = <1>;
				batt_name = "battery_gauge_atlas";
				r_pcb = <24100>;
				batt_indentify_fcc = <1822>;
				soe_dynamic_enable = <0>;
			};
		};

		scharger_v800_flash {
			vendor,led-type = <1>;
			status = "ok";
		};
	};
};

&spmi {
	pmic@0 {
		#address-cells = <1>;
		#size-cells = <0>;
		hi6xxx_coul {
			status = "ok";
			batt: batt {
				batt_index = <0>;
				batt_name = "battery_gauge_aux_atlas";
				r_pcb = <11937>;
				batt_indentify_fcc = <3607>;
				soe_dynamic_enable = <0>;
			};
		};
	};
};

&hisi_vbat_drop_protect {
	vbat_drop_vol_mv = <2517>;
	status = "disabled";
};

&hisi_vbat_drop_protect_v2 {
	vbat_drop_vol_mv = <2600>;
	status = "ok";

	middle_cpu {
		active_perf_limit = <
			33 100 100
			6 15 100
			0 5 100>;
		passive_perf_limit = <
			17 5 10 40 10 0
			6 15 10 70 10 0
			16 100 0 100 10 0>;
	};
};

&hisi_bci_battery {
	battery_design_fcc = <5350>;
	battery_board_type = <19>;
	vth_correct_para = <18 2800>;
	vth_correct_para_low_temp = <18 2600>, <19 2800>;
	status = "ok";
};

&battery_ocv {
	ocv_table =
		"16", "3100",
		"0", "3200",
		"1", "3250";
	status = "ok";
};

&soh_core {
	status = "disabled";
};

&huawei_charger {
	/* Boolean properties — presence means enabled */
	weak_source_sleep_enabled;
	charge_done_sleep_enabled;
	support_new_pd_process = <0>;
	recharge_para = <95 75 4 6 1 0 1 100>;
	status = "ok";
};

&charging_core {
	iin_max = <1800>;
	ichg_max = <2100>;
	iterm_table =
		"-32750", "10", "200",
		"10", "20", "400",
		"45", "32767", "200";
	jeita_table =
		"-32750", "1", "2300", "0", "4200", "0",
		"10", "35", "2300", "3000", "4530", "3",
		"55", "32767", "2300", "0", "4195", "0";
	status = "ok";
};

&charge_mode_test {
	test_para =
		"scp", "lvc", "2017", "105", "0", "2",
		"scp", "sc4", "3000", "105", "0", "0";
	status = "ok";
};

&wireless_charger {
	pmax = <15>;
	trx_plim =
		"5017", "5500", "1200", "-1", "2", "-1", "-1", "-1",
		"12000", "12000", "2300", "-1", "6|9|10", "-1", "3", "-1",
		"12000", "12000", "2300", "-1", "255", "-1", "3|4", "-1";
	sc_err_tx = /bits/ 8 <19>;
	rx_mode_type_para = /bits/ 8 <17 1 1 5 6>;
	rx_mode_para =
		"5W", "5017", "475", "5000", "5500", "825", "4650", "-1", "-1", "-1", "0", "-1", "4",
		"SC_4", "15000", "1800", "15000", "15000", "-1", "-1", "46", "-1", "1", "2", "-1", "-1";
	status = "ok";
};

&wireless_sc {
	init_para_col = <31>;
	init_para =
		"0x13", "SC_2", "0", "1", "3300", "4500", "9000", "450", "300", "100", "300", "10000", "9000", "2",
		"0x4", "SC_4", "2", "1", "3200", "4500", "15000", "500", "300", "100", "300", "20000", "15000", "4";
	volt_para00 =
		"4520", "1550", "340";
	volt_para01 =
		"4067", "4046", "3237",
		"4555", "809", "600";
	bat_para =
		"default", "27", "45", "0x01", "volt_para00",
		"default", "10", "15", "0x02", "volt_para01";
	status = "ok";
};

&direct_charge_ic {
	ic_para1 =
		"1", "0", "5000", "0", "0",
		"1", "1", "5000", "1", "1";
	mode_para =
		"lvc_mode", "ic_para1",
		"sc_mode", "ic_para2",
		"sc4_mode", "ic_para3";
	status = "ok";
};

&direct_charge_comp {
	/* Direct-charge compensation table — float values as strings */
	vbat_comp_ic_para =
		"schargerV800", "30", "7", "3",
		"sc8565", "2", "0.5", "3";
	status = "disabled";
};

&direct_charge_turbo {
	status = "disabled";
	time_para01 =
		"560", "6800", "0", "10500";
	time_para_group =
		"19", "0", "time_para01", "0X1",
		"4", "0", "time_para02", "0X0";
};

&direct_charger {
	use_5A = <0>;
	volt_para =
		"4097", "5000", "3777",
		"4555", "1618", "1200";
	volt_para1 =
		"4517", "5000", "3776",
		"4555", "2697", "1200";
	bat_para =
		"default", "27", "15", "volt_para",
		"CAE", "15", "20", "volt_para1";
	stage_need_to_jump = "0";
	temp_para =
		"-32750", "10", "0",
		"45", "32767", "0";
	resist_para =
		"0", "280", "3000", "280", "32767", "1800";
	status = "ok";
};

&huawei_batt_info {
	status = "ok";
	sn-check-type = <19>;
	battery_checker@0 {
		matchable = <&fm1230 &t91407>;
		spare-cycles = <167>;
		status = "ok";
	};
	battery_checker@1 {
		matchable = <&fm1230_1 &t91407_1>;
		spare-cycles = <167>;
		status = "ok";
	};
};

&fm1230 {
	onewire-gpio = <&gpio2 14 0>;
	battct_id_gpio-supply = <&huawei_batt_identify>;
	ow_reset_start_delay = <317>;
	ow_read_end_delay = <117>;
	status = "ok";
};

&fm1230_1 {
	onewire-gpio = <&gpio2 15 0>;
	battct_id_gpio-supply = <&huawei_batt_identify>;
	ic_index = <0>;
	status = "ok";
};

&fm1230_swi {
	status = "ok";
};

&t91407 {
	onewire-gpio = <&gpio2 14 0>;
	battct_id_gpio-supply = <&huawei_batt_identify>;
	status = "ok";
};

&huawei_batt_identify {
	gpios = <&gpio10 16 0>;
	id_voltage_gpiov = <17 1>;
	status = "ok";
};

&battery_temp_fitting {
	status = "ok";
	btf_temp_lth = "-33";
	fitting_mode = <19>;
	replace_sensor = "bat0_raw_temp";
	temp_para =
		"-32750", "1", "2300", "0", "4200", "0",
		"55", "32767", "2300", "0", "4195", "0";
};

&multi_btb_temp {
	status = "ok";
	sensor-names =
		"bat0_raw_temp", "comp_para", "0",
		"bat1_raw_temp", "comp_para1", "0";
};

&battery_charge_balance {
	status = "ok";
	unbalance_th = <80 9000>;

	battery0 {
		weight = <1822>;
		cccv_0 = <4517 0>;
		cccv_10_20 = <4217 3610
			4250 2707
			4555 1260>;
		temp_tab = "1", "cccv_0",
			"20", "cccv_10_20";
	};

	battery1 {
		weight = <3607>;
		cccv_10_20 = <4217 7180
			4500 3590
			4555 2513>;
		temp_tab = "1", "cccv_0",
			"20", "cccv_10_20";
	};
};

&battery_cccv {
	status = "ok";
	battery_tbl =
		"default", "cccv_para0";
	cccv_para0 {
		buck_cccv_0_5 = <
			4557 1078 0>;
		buck_temp_tab =
			"22", "buck_cccv_0_5";
		cccv_10_20 = <4217 10790 0
			4250 8092 0
			4565 2697 0>;
		temp_tab = "37", "cccv_10_20";
	};
};

&btb_check {
	vol_check_para = "0", "1", "2500", "4700", "120", "3", "0";
	status = "disabled";
};

&boost_5v {
	status = "ok";
	gpio_5v_boost = <&gpio7 27 0>;
};

&amba {
	#address-cells = <2>;
	#size-cells = <2>;
	compatible = "arm,amba-bus";
	interrupt-parent = <&gic>;
	ranges;

	i2c@FF24E000 {
		#address-cells = <1>;
		#size-cells = <0>;
		status = "ok";
		hold-time = <0x190019>;
		mt5788@2B {
			compatible = "mt,mt5788";
			reg = <0x2B>;
			gpio_int = <&gpio6 15 0>;
			gpio_en = <&gpio2 26 0>;
			rx_mod_cm_cfg = /bits/ 8 <0x16 0x5 0x5>;
			rx_ploss_th0 = /bits/ 8 <0x2a 0x32 0x4B 0x64 0x7D 0x96 0xAF 0xE1 0xEB 0x46 0x46 0x46 0x46 0x46 0x46 0x46 0x46 0x46 0x46 0xFF>;
			rx_fod_cond =
				"1", "-1", "2", "5000",
				"31", "-1", "-1", "15000";
			time_para = <1650 1150 0 2200>;
			time_para_group =
				"SC_2", "0", "time_para01",
				"SC_4", "0", "time_para";
			tx_current_fod_para =
				"20", "550", "9900", "300", "9900", "250",
				"12", "195", "9900", "200", "9900", "1";
			prevfod1_product_list = /bits/ 8 <34>;
			status = "ok";
		};

		hl7603@77 {
			compatible = "huawei,bypass_bst_hl7603";
			ic_role = "1";
			reg = <0x77>;
			const_vout = <3500>;
			gpio_enable = <&gpio10 5 0>;
			status = "ok";
		};

		hl7603@75 {
			compatible = "huawei,bypass_bst_hl7603";
			ic_role = "0";
			reg = <0x75>;
			const_vout = <3200>;
			shutdown_cfg =
				"0x1c", "2", "2850",
				"0xc", "2", "2850";
			status = "ok";
		};
	};
};
