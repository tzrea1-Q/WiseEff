/dts-v1/;
/plugin/;

/* Board-level configuration */
/ {
	board_id = <12345>;
};

&amba {
	i2c@FDF5E000 {
		status = "ok";
		hold-time = <0x220022>;
		sc8562@6E {
			compatible = "sc8562";
			slave_mode = <0>;
			ic_role = <1>;
			reg = <0x6e>;
			fcp_support = <0>;
			scp_support = <0>;
			gpio_int = <&gpio13 29 0>;
			sense_r_config = <10>;
			sense_r_actual = <10>;
			watchdog_time = <5000>;
			vout_ovp_mv = <5000>;
			status = "ok";
		};
	};
};

&spmi1 {
	scharger_v800 {
		gpios = <&gpio5 31 0>;
		status = "ok";
		scharger_v800_buck {
			r_charger_uohm = <1000>;
			usbovp_sw_flag = "buck", "0", "1", "1";
			pswovp_sw_flag = "rxsw", "1", "0", "1";
			cur_balance_mos = <2>;
		};

		scharger_v800_coul {
			status = "ok";
			batt_l_v800 {
				batt_index = <0>;
				batt_name = "battery_gauge";
				r_pcb = <23330>;
				batt_indentify_fcc = <1805>;
				soe_dynamic_enable = <1>;
			};
		};

		scharger_v800_flash {
			vendor,led-type = <0>;
			status = "ok";
		};
	};
};

&spmi {
	pmic@0 {
		hi6xxx_coul {
			status = "ok";
			batt:batt{
				batt_index = <1>;
				batt_name = "battery_gauge_aux";
				r_pcb = <11920>;
				batt_indentify_fcc = <3590>;
				soe_dynamic_enable = <1>;
			};
		};
	};
};

&hisi_vbat_drop_protect {
	vbat_drop_vol_mv = <2500>;
	status = "disabled";
};

&hisi_vbat_drop_protect_v2 {
	vbat_drop_vol_mv = <2500>;
	status = "ok";

	middle_cpu {
		active_perf_limit  = <
			16 100 100
			6 15 100
			0 5 100>;
		passive_perf_limit = <
			0 5 10 40 10 0
			6 15 10 70 10 0
			16 100 0 100 10 0>;
	};
};

&hisi_bci_battery {
	battery_design_fcc = <5525>;
	battery_board_type = <2>;
	vth_correct_para = <1 2800>;
	vth_correct_para_low_temp = <1 2600>,<2 2800>;
	status = "ok";
};

&battery_ocv {
	ocv_table =
		"-1", "3100",
		"0", "3200",
		"1", "3250";
	status = "ok";
};

&soh_core {
	status = "disabled";
};

&huawei_charger {
	/* Boolean properties — presence means enabled */
	weak_source_sleep_enabled;
	charge_done_sleep_enabled;
	support_new_pd_process = <1>;
	recharge_para = <96 60 3 5 1 0 1 100>;
	status = "ok";
};

&charging_core {
	iin_max = <2300>;
	ichg_max = <2500>;
	iterm_table =
		"-32767", "10", "200",
		"10", "20", "400",
		"45", "32767", "200";
	jeita_table =
		"-32767", "1", "2300", "0", "4200", "0",
		"10", "35", "2300", "3000", "4530", "3",
		"55", "32767", "2300", "0", "4195", "0";
	status = "ok";
};

&charge_mode_test {
	test_para =
		"scp", "lvc", "2000", "105", "0", "2",
		"scp", "sc4", "3000", "105", "0", "0";
	status = "ok";
};

&wireless_charger {
	pmax = <25>;
	trx_plim =
		"5000",  "5500",  "1200", "-1", "2", "-1", "-1", "-1",
		"12000", "12000", "2300", "-1", "6|9|10", "-1", "3", "-1",
		"12000", "12000", "2300", "-1", "255", "-1", "3|4", "-1";
	sc_err_tx = /bits/ 8 <2>;
	rx_mode_type_para = /bits/ 8 <0 1 1 5 6>;
	rx_mode_para =
		"5W",   "5000",  "475",  "5000",  "5500",  "825", "4650", "-1", "-1", "-1", "0", "-1", "4",
		"SC_4", "15000", "1800", "15000", "15000", "-1", "-1",   "46", "-1", "1",  "2", "-1", "-1";
	status = "ok";
};

&wireless_sc {
	init_para_col = <14>;
	init_para =
		"0x2", "SC_2", "0", "1", "3300", "4500", "9000",  "450", "300", "100", "300", "10000", "9000",  "2",
		"0x4", "SC_4", "2", "1", "3200", "4500", "15000", "500", "300", "100", "300", "20000", "15000", "4";
	volt_para00 =
		"4555", "1802", "386";
	volt_para01 =
		"4050", "4046", "3237",
		"4555", "809", "600";
	bat_para =
		"default", "10", "45", "0x01", "volt_para00",
		"default", "10", "15", "0x02", "volt_para01";
	status = "ok";
};

&direct_charge_ic {
	ic_para1 =
		"0", "0", "5000", "0", "0",
		"1", "1", "5000", "1", "1";
	mode_para =
		"lvc_mode", "ic_para1",
		"sc_mode", "ic_para2",
		"sc4_mode", "ic_para3";
	status = "ok";
};

&direct_charge_comp {
	/* Direct-charge compensation table — float values as strings */
	vbat_comp_ic_para =
		"schargerV800", "13", "7", "3",
		"sc8565", "2", "0.5", "3";
	status = "disabled";
};

&direct_charge_turbo {
	status = "ok";
	time_para01 =
		"640", "7200",
		"0", "12500";
	time_para_group =
		"2", "0", "time_para01", "0X1",
		"4", "0", "time_para02", "0X0";
};

&direct_charger {
	use_5A = <1>;
	volt_para =
		"4080", "5000", "3777",
		"4555", "1618", "1200";
	volt_para1 =
		"4500", "5000", "3776",
		"4555", "2697", "1200";
	bat_para =
		"default", "10", "15", "volt_para",
		"CAE", "15", "20", "volt_para1";
	stage_need_to_jump = "1";
	temp_para =
		"-32767", "10", "0",
		"45", "32767", "0";
	resist_para =
		"0", "260", "3300",
		"260", "32767", "2000";
	status = "ok";
};

&huawei_batt_info {
	status = "ok";
	sn-check-type = <2>;
	battery_checker@0 {
		matchable = <&fm1230 &t91407>;
		spare-cycles = <150>;
		status = "ok";
	};
	battery_checker@1 {
		matchable = <&fm1230_1 &t91407_1>;
		spare-cycles = <150>;
		status = "ok";
	};
};

&fm1230 {
	onewire-gpio = <&gpio2 14 0>;
	battct_id_gpio-supply = <&huawei_batt_identify>;
	ow_reset_start_delay = <300>;
	ow_read_end_delay = <100>;
	status = "ok";
};

&fm1230_1 {
	onewire-gpio = <&gpio2 15 0>;
	battct_id_gpio-supply = <&huawei_batt_identify>;
	ic_index = <1>;
	status = "ok";
};

&fm1230_swi {
	status = "ok";
};

&t91407 {
	onewire-gpio = <&gpio2 14 0>;
	battct_id_gpio-supply = <&huawei_batt_identify>;
	status = "ok";
};

&huawei_batt_identify {
	gpios = <&gpio10 16 0>;
	id_voltage_gpiov = <0 1>;
	status = "ok";
};

&battery_temp_fitting {
	status = "ok";
	btf_temp_lth = "-50";
	fitting_mode = <2>;
	replace_sensor = "bat0_raw_temp";
	temp_para =
		"-32767", "1", "2300", "0", "4200", "0",
		"55", "32767", "2300", "0", "4195", "0";
};

&multi_btb_temp {
	status = "ok";
	sensor-names =
		"bat0_raw_temp", "comp_para", "0",
		"bat1_raw_temp", "comp_para1", "0";
};

&battery_charge_balance {
	status = "ok";
	unbalance_th = <100 10000>;

	battery0 {
		weight = <1805>;
		cccv_0 = <4500 0>;
		cccv_10_20 = <4200 3610
			4250 2707
			4555 1260>;
		temp_tab = "0", "cccv_0",
			"20", "cccv_10_20";
	};

	battery1 {
		weight = <3590>;
		cccv_10_20 = <4200 7180
			4500 3590
			4555 2513>;
		temp_tab = "0", "cccv_0",
			"20", "cccv_10_20";
	};
};

&battery_cccv {
	status = "ok";
	battery_tbl =
		"default", "cccv_para0";
	cccv_para0 {
		buck_cccv_0_5 = <4540 1078 0>;
		buck_temp_tab =
			"5", "buck_cccv_0_5";
		cccv_10_20 = <4200 10790 0
			4250 8092 0
			4565 2697 0>;
		temp_tab = "20", "cccv_10_20";
	};
};

&btb_check {
	vol_check_para = "1", "1", "2500", "4700", "120", "3", "0";
	status = "disabled";
};

&boost_5v {
	status = "ok";
	gpio_5v_boost = <&gpio7 27 0>;
};

&amba {
	#address-cells = <2>;
	#size-cells = <2>;
	compatible = "arm,amba-bus";
	interrupt-parent = <&gic>;
	ranges;

	i2c@FF24E000 {
		status = "ok";
		hold-time = <0x190019>;
		mt5788@2B {
			compatible = "mt,mt5788";
			reg = <0x2B>;
			gpio_int = <&gpio6 15 0>;
			gpio_en = <&gpio2 26 0>;
			rx_mod_cm_cfg = /bits/ 8 <0x5 0x5 0x5>;
			rx_ploss_th0 = /bits/ 8 <0x19 0x32 0x4B 0x64 0x7D 0x96 0xAF 0xE1 0xEB 0x46 0x46 0x46 0x46 0x46 0x46 0x46 0x46 0x46 0x46 0xFF>;
			rx_fod_cond =
				"0", "-1", "2", "5000",
				"31", "-1", "-1", "15000";
			time_para = <
				1800 1250
				0 2500
			>;
			time_para_group =
				"SC_2", "1", "time_para01",
				"SC_4", "0", "time_para";
			tx_current_fod_para =
				"3", "550", "9900", "300", "9900", "250",
				"12", "195", "9900", "200", "9900", "1";
			prevfod1_product_list = /bits/ 8 <17>;
			status = "ok";
		};

		hl7603@77 {
			compatible = "huawei,bypass_bst_hl7603";
			ic_role = "0";
			reg = <0x77>;
			const_vout = <3600>;
			gpio_enable = <&gpio10 5 0>;
			status = "ok";
		};

		hl7603@75 {
			compatible = "huawei,bypass_bst_hl7603";
			ic_role = "1";
			reg = <0x75>;
			const_vout = <3300>;
			shutdown_cfg =
				"0xb", "2", "2850",
				"0xc", "2", "2850";
			status = "ok";
		};
	};
};
