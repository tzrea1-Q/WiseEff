# WiseEff local non-HDC staging profile.
# Copy this file to .env, fill the three blank AGENT_* values, then run:
# npm run dev:all
# The one-command launcher starts Docker PostgreSQL, runs migrations/seeds,
# starts the API, and starts the API-mode Vite frontend.

NODE_ENV=development
PORT=8787
HOST=127.0.0.1

# Local PostgreSQL created for WiseEff development.
DATABASE_URL=postgres://wiseeff:wiseeff@127.0.0.1:5432/wiseeff

# Production-mode auth for local account login/register.
AUTH_MODE=production
AUTH_PROVIDER=local

# Optional HMAC smoke token inputs. Switch AUTH_PROVIDER=hmac only for local smoke/test checks.
AUTH_TOKEN_ISSUER=wiseeff-local
AUTH_TOKEN_HMAC_SECRET=wiseeff-local-hmac-secret-32-chars-minimum
M5_SMOKE_AUTHORIZATION=Bearer .TBck5Wa4LBQuIBb4id8HAQYh_sD_RKFyGsMLGfy-PU0
WISEEFF_SMOKE_AUTHORIZATION=Bearer .TBck5Wa4LBQuIBb4id8HAQYh_sD_RKFyGsMLGfy-PU0

# API clients and frontend API runtime (default for local dev).
WISEEFF_API_BASE_URL=http://127.0.0.1:8787
VITE_WISEEFF_RUNTIME_MODE=api
VITE_WISEEFF_API_BASE_URL=http://127.0.0.1:8787

# Target self-hosted deployments that require SSO/MFA use OIDC instead of local accounts.
# AUTH_PROVIDER=oidc
# AUTH_OIDC_ISSUER=https://id.example.com/realms/wiseeff
# AUTH_OIDC_AUDIENCE=wiseeff-api
# AUTH_OIDC_JWKS_URI=
# M6_IDENTITY_AUTHORIZATION=
# M6_IDENTITY_WRONG_ISSUER_AUTHORIZATION=
# M6_IDENTITY_WRONG_AUDIENCE_AUTHORIZATION=
# M6_IDENTITY_EXPIRED_AUTHORIZATION=

# Local file-backed object storage. S3/OSS values are only required for real production.
OBJECT_STORE_MODE=local
OBJECT_STORE_ROOT=.wiseeff-object-store

# Local backup/restore working directories. Local drills prove evidence shape and safety only.
# Record M5_BACKUP_RESTORE_DRILL_AT only after a real target restore drill passes.
WISEEFF_LOCAL_BACKUP_DIR=.wiseeff-backups
WISEEFF_LOCAL_RESTORE_DIR=.wiseeff-restore
OBJECT_STORAGE_PROVIDER=s3-compatible-local
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=wiseeff-local
OBJECT_STORAGE_HEALTH_PREFIX=.health/
OBJECT_STORAGE_TLS_POLICY=required
OBJECT_STORAGE_PATH_STYLE=true
OBJECT_STORAGE_RETENTION_CLASS=local-default
BACKUP_DRILL_ENVIRONMENT=local-non-customer
BACKUP_DATABASE_COMMAND=pg_dump --format=custom
BACKUP_DATABASE_TARGET=file://.wiseeff-backups/postgres/wiseeff.dump
BACKUP_OBJECT_STORAGE_TARGET=file://.wiseeff-backups/object-store/
RESTORE_DATABASE_URL=postgres://wiseeff_restore:wiseeff_restore@127.0.0.1:5432/wiseeff_restore
RESTORE_OBJECT_STORAGE_BUCKET=wiseeff-restore
RESTORE_OBJECT_STORAGE_PREFIX=m6-drill/

# Non-HDC local staging policy. DEBUG_DEVICE_GATEWAY_MODE supports simulator, hdc, adb, or multi.
DEBUG_DEVICE_GATEWAY_MODE=multi
DEVICE_GATEWAY_ALLOW_SIMULATOR_IN_PRODUCTION=true
HDC_TIMEOUT_MS=5000
ADB_TIMEOUT_MS=5000

# Local device bridge artifact manifest and pairing/token lifetimes.
DEVICE_BRIDGE_ARTIFACT_ROOT=ops/self-hosted/bridge-artifacts
DEVICE_BRIDGE_TOOL_ARTIFACT_ROOT=ops/self-hosted/bridge-tool-artifacts
DEVICE_BRIDGE_PAIRING_TTL_SECONDS=1800
DEVICE_BRIDGE_TOKEN_TTL_DAYS=90
# Conditional local bridge lab acceptance gates.
DEVICE_BRIDGE_LAB_AVAILABLE=false
DEVICE_BRIDGE_SERVER_URL=http://127.0.0.1:8787

# Live Agent provider. Use AGENT_API_FORMAT=openai for OpenAI-compatible transport or wiseeff for the native HTTP transport.
AGENT_PROVIDER=live
AGENT_API_FORMAT=wiseeff
AGENT_API_BASE_URL=
AGENT_MODEL=
AGENT_API_KEY=
AGENT_API_TIMEOUT_MS=30000
AGENT_PROMPT_VERSION=m5-agent-v1

# Xiaoze (小泽) AG-UI agent (P0 perception + P1 action).
XIAOZE_RUNTIME_ENABLED=true
XIAOZE_MODEL=
XIAOZE_PROACTIVE_ENABLED=false
VITE_XIAOZE_ENABLED=true
VITE_XIAOZE_PROACTIVE_ENABLED=false
VITE_XIAOZE_PROMPT_DEBUG=false

# Local M5 smoke evidence inputs.
M5_CONTRACT_CHECK_PASSED=true
M5_SMOKE_ALLOW_NO_API=false

# Local API starts the log worker in-process. Self-hosted API containers set this to false and run a separate worker service.
LOG_WORKER_ENABLED=true
LOG_ANALYSIS_QUEUE_MODE=polling
REDIS_URL=redis://127.0.0.1:6379
LOG_ANALYSIS_QUEUE_PREFIX=wiseeff
LOG_ANALYSIS_QUEUE_ATTEMPTS=4
LOG_ANALYSIS_QUEUE_BACKOFF_MS=1000
LOG_ANALYSIS_QUEUE_CONCURRENCY=1

# Production object storage example, intentionally commented out for the local profile.
# OBJECT_STORE_MODE=s3
# OBJECT_STORAGE_ENDPOINT=https://storage.example.com
# OBJECT_STORAGE_BUCKET=wiseeff-pilot
# OBJECT_STORAGE_ACCESS_KEY_ID=...
# OBJECT_STORAGE_SECRET_ACCESS_KEY=...
# OBJECT_STORAGE_REGION=ap-southeast-1
