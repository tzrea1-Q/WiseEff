# WiseEff local non-HDC staging profile.
# Copy this file to .env, fill the three blank AGENT_* values, then run:
# npm run dev:all
# The one-command launcher starts Docker PostgreSQL, runs migrations/seeds,
# starts the API, and starts the API-mode Vite frontend.

NODE_ENV=development
PORT=8787
HOST=127.0.0.1

# Local PostgreSQL created for WiseEff development.
DATABASE_URL=postgres://wiseeff:wiseeff@127.0.0.1:5432/wiseeff

# Production-mode auth for local smoke checks.
AUTH_MODE=production
AUTH_TOKEN_ISSUER=wiseeff-local
AUTH_TOKEN_HMAC_SECRET=wiseeff-local-hmac-secret-32-chars-minimum
M5_SMOKE_AUTHORIZATION=Bearer .TBck5Wa4LBQuIBb4id8HAQYh_sD_RKFyGsMLGfy-PU0
WISEEFF_SMOKE_AUTHORIZATION=Bearer .TBck5Wa4LBQuIBb4id8HAQYh_sD_RKFyGsMLGfy-PU0

# API clients and frontend API runtime.
WISEEFF_API_BASE_URL=http://127.0.0.1:8787
VITE_WISEEFF_RUNTIME_MODE=api
VITE_WISEEFF_API_BASE_URL=http://127.0.0.1:8787

# Local file-backed object storage. S3/OSS values are only required for real production.
OBJECT_STORE_MODE=local
OBJECT_STORE_ROOT=.wiseeff-object-store

# Local backup/restore working directories. Record M5_BACKUP_RESTORE_DRILL_AT only after a real drill passes.
WISEEFF_LOCAL_BACKUP_DIR=.wiseeff-backups
WISEEFF_LOCAL_RESTORE_DIR=.wiseeff-restore

# Non-HDC local staging policy.
DEBUG_DEVICE_GATEWAY_MODE=simulator
DEVICE_GATEWAY_ALLOW_SIMULATOR_IN_PRODUCTION=true
HDC_TIMEOUT_MS=5000

# OpenAI-compatible live Agent provider. Fill these three blanks before starting the API.
AGENT_PROVIDER=live
AGENT_API_FORMAT=openai
AGENT_API_BASE_URL=
AGENT_MODEL=
AGENT_API_KEY=
AGENT_API_TIMEOUT_MS=30000
AGENT_PROMPT_VERSION=m5-agent-v1

# Local M5 smoke evidence inputs.
M5_CONTRACT_CHECK_PASSED=true
M5_SMOKE_ALLOW_NO_API=false

# Local API starts the log worker in-process. Self-hosted API containers set this to false and run a separate worker service.
LOG_WORKER_ENABLED=true
LOG_ANALYSIS_QUEUE_MODE=polling
REDIS_URL=redis://127.0.0.1:6379
LOG_ANALYSIS_QUEUE_PREFIX=wiseeff
LOG_ANALYSIS_QUEUE_ATTEMPTS=4
LOG_ANALYSIS_QUEUE_BACKOFF_MS=1000
LOG_ANALYSIS_QUEUE_CONCURRENCY=1

# Production object storage example, intentionally commented out for the local profile.
# OBJECT_STORE_MODE=s3
# OBJECT_STORAGE_ENDPOINT=https://storage.example.com
# OBJECT_STORAGE_BUCKET=wiseeff-pilot
# OBJECT_STORAGE_ACCESS_KEY_ID=...
# OBJECT_STORAGE_SECRET_ACCESS_KEY=...
# OBJECT_STORAGE_REGION=ap-southeast-1
