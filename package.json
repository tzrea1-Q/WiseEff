{
  "name": "core-efficiency-prototype",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:api": "tsx watch server/index.ts",
    "worker:logs": "tsx server/modules/logs/workerRunner.ts",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:server": "vitest run --config vitest.server.config.ts",
    "test:all": "npm test && npm run test:server",
    "test:e2e": "playwright test",
    "test:m1": "npm run test:all && npm run build && npm run test:e2e",
    "test:m2": "npm run test:all && npm run build && npm run test:e2e",
    "test:m3": "npm run test:all && npm run build && npm run test:e2e -- e2e/debugging.api.spec.ts",
    "test:m3-5": "npm run test:all && npm run build && npm run test:e2e -- e2e/debugging.api.spec.ts",
    "test:m4": "npm run test:all && npm run build && npm run test:e2e -- e2e/agent.api.spec.ts",
    "smoke:m5": "tsx scripts/run-m5-smoke.ts",
    "test:m5": "npm run contract:check && npm run test:all && npm run build && npm run test:e2e && npm run smoke:m5",
    "contract:openapi": "tsx scripts/generate-openapi-contract.ts",
    "contract:check": "tsx scripts/check-openapi-contract.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed:m0": "tsx scripts/seed-m0.ts",
    "db:seed:m1": "tsx scripts/seed-m1-parameters.ts",
    "db:seed:m2": "tsx scripts/seed-m2-logs.ts",
    "db:seed:m3": "tsx scripts/seed-m3-debugging.ts",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "lucide-react": "^0.561.0",
    "pg": "^8.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.3.0",
    "playwright": "^1.57.0",
    "tsx": "^4.20.3",
    "vitest": "^4.0.16"
  }
}
