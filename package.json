{
  "name": "core-efficiency-prototype",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "VITE_WISEEFF_RUNTIME_MODE=api VITE_WISEEFF_API_BASE_URL=http://127.0.0.1:8787 vite --host 127.0.0.1",
    "dev:all": "tsx scripts/run-dev-all.ts",
    "dev:api": "tsx watch server/index.ts",
    "worker:logs": "tsx server/modules/logs/workerRunner.ts",
    "build": "NODE_OPTIONS='--max-old-space-size=1024' tsc -b && NODE_OPTIONS='--max-old-space-size=1024' vite build",
    "test": "NODE_OPTIONS='--max-old-space-size=768' tsx scripts/run-vitest.ts",
    "test:server": "NODE_OPTIONS='--max-old-space-size=768' vitest run --config vitest.server.config.ts",
    "test:all": "npm test && npm run test:server",
    "test:e2e": "playwright test",
    "test:m1": "npm run test:m2",
    "test:m2": "npm run test:all && npm run build && npm run test:e2e",
    "test:m3": "npm run test:m3-5",
    "test:m3-5": "npm run test:all && npm run build && npm run test:e2e -- e2e/debugging.api.spec.ts",
    "smoke:m5": "tsx scripts/run-m5-smoke.ts",
    "acceptance:preflight": "tsx -- scripts/run-acceptance-preflight.ts",
    "acceptance:e2e": "playwright test --config playwright.acceptance.config.ts",
    "acceptance:browser": "tsx -- scripts/run-browser-acceptance.ts",
    "acceptance:coverage": "tsx scripts/check-acceptance-coverage.ts",
    "acceptance:operations": "tsx scripts/check-acceptance-operation-matrix.ts",
    "acceptance:models": "tsx scripts/check-acceptance-state-models.ts",
    "acceptance:evidence": "tsx scripts/check-operation-evidence.ts",
    "acceptance:ci": "tsx scripts/check-acceptance-ci.ts",
    "acceptance:a11y": "playwright test --config playwright.quality.config.ts --project a11y",
    "acceptance:visual": "playwright test --config playwright.quality.config.ts --project visual",
    "acceptance:responsive": "playwright test --config playwright.quality.config.ts --project responsive",
    "acceptance:quality": "tsx scripts/check-quality-gates.ts",
    "observability:check": "tsx scripts/check-observability-config.ts",
    "backup:drill": "tsx scripts/run-backup-drill.ts",
    "restore:drill": "tsx scripts/run-restore-drill.ts",
    "backup:check": "tsx scripts/check-backup-drill.ts",
    "identity:local-oidc-drill": "tsx scripts/run-local-oidc-identity-drill.ts",
    "identity:check": "tsx scripts/check-identity-evidence.ts",
    "queue:check": "tsx scripts/check-durable-queue.ts",
    "observability:target-evidence": "tsx scripts/write-observability-target-evidence.ts",
    "selfhost:check": "tsx ops/self-hosted/scripts/check-self-hosted-config.ts",
    "selfhost:smoke": "tsx ops/self-hosted/scripts/run-self-hosted-smoke.ts",
    "selfhost:release-gate": "tsx scripts/run-self-hosted-release-gate.ts",
    "capacity:gate": "tsx scripts/run-capacity-gate.ts",
    "rollback:rehearsal": "tsx scripts/run-rollback-rehearsal.ts",
    "m6:target-plan": "tsx -- scripts/plan-m6-target-evidence.ts",
    "m6:target-evidence": "tsx scripts/check-m6-target-evidence.ts",
    "test:m5": "npm run contract:check && npm run test:all && npm run build && npm run test:e2e && tsx scripts/run-m5-smoke.ts --require-api",
    "contract:openapi": "tsx scripts/generate-openapi-contract.ts",
    "contract:check": "tsx scripts/check-openapi-contract.ts",
    "docs:check": "tsx scripts/check-doc-governance.ts",
    "xiaoze:eval": "tsx scripts/run-xiaoze-eval.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "reset:quality-runtime": "tsx scripts/reset-quality-runtime.ts",
    "db:seed:m0": "tsx scripts/seed-m0.ts",
    "db:seed:m1": "tsx scripts/seed-m1-parameters.ts",
    "db:seed:m2": "tsx scripts/seed-m2-logs.ts",
    "db:seed:m3": "tsx scripts/seed-m3-debugging.ts",
    "db:seed:all": "tsx scripts/seed-all.ts",
    "admin:bootstrap": "tsx scripts/bootstrap-local-admin.ts",
    "preview": "vite preview --host 127.0.0.1",
    "bridge:test": "vitest run --config vitest.bridge.config.ts",
    "bridge:build": "tsx scripts/build-device-bridge.ts",
    "build:bridge-installers": "tsx scripts/build-bridge-installers.ts",
    "bridge-tool-artifacts:prepare": "tsx scripts/prepare-bridge-tool-artifacts.ts",
    "bridge-tool-artifacts:hash": "tsx scripts/build-bridge-tool-artifacts.ts"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.57",
    "@ag-ui/core": "^0.0.57",
    "@copilotkit/react-core": "^1.61.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.5",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.4",
    "@langchain/openai": "^1.5.3",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@wiseeff/device-command-core": "workspace:*",
    "bullmq": "^5.78.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "ioredis": "^5.11.0",
    "lucide-react": "^0.561.0",
    "pg": "^8.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "ws": "^8.21.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "fast-check": "^4.8.0",
    "jsdom": "^27.3.0",
    "playwright": "^1.57.0",
    "tsx": "^4.20.3",
    "vitest": "^4.0.16"
  }
}
