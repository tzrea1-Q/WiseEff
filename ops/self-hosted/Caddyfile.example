{
  email {$WISEEFF_TLS_EMAIL}
}

{$WISEEFF_SITE_HOST} {
  tls {$WISEEFF_TLS_EMAIL}

  handle /api/* {
    reverse_proxy api:8787
  }

  handle /health/* {
    reverse_proxy api:8787
  }

  handle /downloads/device-bridge/* {
    uri strip_prefix /downloads/device-bridge
    root * /bridge-artifacts
    file_server
  }

  handle /downloads/device-bridge-tools/* {
    uri strip_prefix /downloads/device-bridge-tools
    root * /bridge-tool-artifacts
    file_server
  }

  handle {
    reverse_proxy web:5173
  }
}
