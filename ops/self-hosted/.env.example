# WiseEff M6.1 self-hosted Linux profile.
# Copy to ops/self-hosted/.env, fill secrets, then run from this directory:
# docker compose --env-file .env up -d --build

NODE_ENV=production
HOST=0.0.0.0
PORT=8787

# Public or private DNS name served by Caddy.
WISEEFF_SITE_HOST=wiseeff.example.com
WISEEFF_TLS_EMAIL=ops@example.com

# PostgreSQL service created by ops/self-hosted/compose.yaml.
POSTGRES_PASSWORD=
DATABASE_URL=postgres://wiseeff:${POSTGRES_PASSWORD}@postgres:5432/wiseeff

# Production identity uses self-hosted OIDC. Keep HMAC only for local smoke/test profiles.
AUTH_MODE=production
AUTH_PROVIDER=oidc
AUTH_OIDC_ISSUER=https://id.example.com/realms/wiseeff
AUTH_OIDC_AUDIENCE=wiseeff-api
AUTH_OIDC_JWKS_URI=
M6_SELFHOSTED_SMOKE_AUTHORIZATION=

# Compatibility-only local smoke token names. Target evidence should use an OIDC access token.
M5_SMOKE_AUTHORIZATION=
WISEEFF_SMOKE_AUTHORIZATION=

# Browser/API runtime.
WISEEFF_API_BASE_URL=https://${WISEEFF_SITE_HOST}
VITE_WISEEFF_RUNTIME_MODE=api
VITE_WISEEFF_API_BASE_URL=https://${WISEEFF_SITE_HOST}

# M6.1 requires a production-shaped S3-compatible object store, but M6.3
# chooses and deploys the final self-hosted provider.
OBJECT_STORE_MODE=s3
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_TLS_POLICY=required
OBJECT_STORAGE_PATH_STYLE=true
OBJECT_STORAGE_HEALTH_PREFIX=.health/
OBJECT_STORAGE_RETENTION_CLASS=pilot-default

# M6.3 backup/restore drill targets. Restore targets must be isolated and
# must never equal DATABASE_URL or OBJECT_STORAGE_BUCKET.
BACKUP_DATABASE_TARGET=file:///var/backups/wiseeff/postgres/wiseeff.dump
BACKUP_OBJECT_STORAGE_TARGET=file:///var/backups/wiseeff/object-store/
RESTORE_DATABASE_URL=postgres://wiseeff_restore:restore-password@postgres:5432/wiseeff_restore
RESTORE_OBJECT_STORAGE_BUCKET=wiseeff-restore
RESTORE_OBJECT_STORAGE_PREFIX=m6-drill/

# Non-HDC staging can use simulator mode. Customer production signoff must
# switch to hdc and provide HDC device-lab evidence.
DEBUG_DEVICE_GATEWAY_MODE=simulator
DEVICE_GATEWAY_ALLOW_SIMULATOR_IN_PRODUCTION=true
HDC_TIMEOUT_MS=5000

# OpenAI-compatible live Agent provider.
AGENT_PROVIDER=live
AGENT_API_FORMAT=openai
AGENT_API_BASE_URL=
AGENT_MODEL=
AGENT_API_KEY=
AGENT_API_TIMEOUT_MS=30000
AGENT_PROMPT_VERSION=m5-agent-v1

# API container disables the in-process worker; the worker service runs it.
LOG_WORKER_ENABLED=false
LOG_ANALYSIS_QUEUE_MODE=durable
REDIS_URL=redis://redis:6379
LOG_ANALYSIS_QUEUE_PREFIX=wiseeff
LOG_ANALYSIS_QUEUE_ATTEMPTS=4
LOG_ANALYSIS_QUEUE_BACKOFF_MS=1000
LOG_ANALYSIS_QUEUE_CONCURRENCY=1

# Evidence knobs used by smoke/pilot-readiness.
M5_CONTRACT_CHECK_PASSED=true
M5_BACKUP_RESTORE_DRILL_AT=
M5_SMOKE_ALLOW_NO_API=false
